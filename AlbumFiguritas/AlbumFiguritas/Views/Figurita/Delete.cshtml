@model AlbumFiguritas.Models.Figurita

@{
    ViewData["Title"] = "Delete";
}

<h1>Borrar</h1>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Numero)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Numero)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NombreJugador)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NombreJugador)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Seleccion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Seleccion)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UrlFotoJugador)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UrlFotoJugador)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UsuariosPoseen)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UsuariosPoseen)
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Eliminar" class="btn btn-danger" />
    </form>
    <a class="btn btn-outline-warning mt-3" asp-action="Index">Volver</a>
</div>
