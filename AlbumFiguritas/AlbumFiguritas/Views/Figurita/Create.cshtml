@model AlbumFiguritas.Models.Figurita

@{
    ViewData["Title"] = "Create";
}

<h4>Figurita</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Numero" class="control-label"></label>
                <input asp-for="Numero" class="form-control" />
                <span asp-validation-for="Numero" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NombreJugador" class="control-label"></label>
                <input asp-for="NombreJugador" class="form-control" />
                <span asp-validation-for="NombreJugador" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Seleccion" class="control-label"></label>
                <input asp-for="Seleccion" class="form-control" />
                <span asp-validation-for="Seleccion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Foto del Jugador</label>
                <input type="file" name="imagenArchivo" class="form-control" accept="image/*" required />
            </div>


            <div class="form-group mt-4">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-warning">Volver</a>
</div>