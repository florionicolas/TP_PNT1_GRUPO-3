@model AlbumFiguritas.Models.Figurita

@{
    ViewData["Title"] = "Create";
}

<h1>Agregar Figurita</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Numero" class="control-label"></label>
                <input asp-for="Numero" class="form-control" />
                <span asp-validation-for="Numero" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NombreJugador" class="control-label"></label>
                <input asp-for="NombreJugador" class="form-control" />
                <span asp-validation-for="NombreJugador" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Seleccion" class="control-label"></label>
                <input asp-for="Seleccion" class="form-control" />
                <span asp-validation-for="Seleccion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UrlFotoJugador" class="control-label"></label>
                <input asp-for="UrlFotoJugador" class="form-control" />
                <span asp-validation-for="UrlFotoJugador" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UsuariosPoseen" class="control-label"></label>
                <input asp-for="UsuariosPoseen" class="form-control" />
                <span asp-validation-for="UsuariosPoseen" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Agregar" class="btn btn-outline-primary mt-3 text-white" />
            </div>     
        </form>
        <div>
            <a class="btn btn-outline-warning mt-3" asp-action="Index">Volver</a>
        </div>
    </div>
</div>


