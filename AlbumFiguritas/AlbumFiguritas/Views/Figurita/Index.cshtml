@model IEnumerable<AlbumFiguritas.Models.Figurita>

@{
    ViewData["Title"] = "Listado de Figuritas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Listado de Figuritas</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Agregar Figurita</a>
    </div>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4 text-center">

        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-secondary bg-dark text-white">

                    <div class="p-2 bg-secondary rounded-top">
                        @if (!string.IsNullOrEmpty(item.UrlFotoJugador))
                        {
                            <img src="~/@item.UrlFotoJugador"
                                 alt="Foto de @item.NombreJugador"
                                 class="card-img-top img-fluid rounded shadow-sm"
                                 style="width:150px;  height: 210px; object-fit: cover;"
                                 onerror="this.onerror=null;this.src='/img/default.png';" />
                        }
                        else
                        {
                            <img src="/img/default.png" class="card-img-top img-fluid rounded" style="height: 200px; object-fit: cover;" />
                        }
                    </div>

                    <div class="card-body d-flex flex-column justify-content-between p-3">

                        <div>
                            <span class="badge bg-light text-dark mb-1">#@item.Numero</span>
                            <h6 class="card-title font-weight-bold text-truncate m-0" title="@item.NombreJugador">
                                @item.NombreJugador
                            </h6>
                            <p class="card-text text-muted small mt-1 mb-0">@item.Seleccion</p>
                        </div>

                        <div class="d-flex justify-content-center gap-1 mt-3">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Editar">
                                ✏️
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white" title="Detalles">
                                ℹ️
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Borrar">
                                ❌
                            </a>
                        </div>

                    </div>

                </div>
            </div>
        }
    </div>
</div>
