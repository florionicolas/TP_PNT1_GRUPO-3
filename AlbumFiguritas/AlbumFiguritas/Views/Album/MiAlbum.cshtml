@{
    ViewData["Title"] = "Mi Album";
}

<div class="dashboard-container mt-5">

    <h2 class="text-center mb-4">Mi Album</h2>
    <h5 class="text-center mb-4">Progreso</h5>
    <div class="progress-custom mb-5 d-flex">

        <div class="bg-dark px-3 d-flex align-items-center" style="z-index: 2;">
            ⭐
        </div>

        <div class="flex-grow-1 position-relative">

            <div class="progress-bar-custom h-100" style="width: @Model.PorcentajeCompletado.ToString(System.Globalization.CultureInfo.InvariantCulture)%;">
            </div>

            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                <span class="fw-bold" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.8);">
                    @Model.PorcentajeCompletado% Completo
                </span>
            </div>

        </div>
    </div>

    <div class="row text-center mb-5 mt-4">

        <div class="col-md-4">
            <h4>Obtenidas</h4>
            <div class="stat-circle circle-green mt-3">
                @Model.TotalObtenidas
            </div>
        </div>

        <div class="col-md-4">
            <h4>Faltantes</h4>
            <div class="stat-circle circle-pink mt-3">
                @Model.TotalFaltantes
            </div>
        </div>

        <div class="col-md-4">
            <h4>Repetidas</h4>
            <div class="stat-circle circle-yellow mt-3">
                @Model.TotalRepetidas
            </div>
        </div>

    </div>

    <div class="mt-5">
        <h5 class="mb-3">Figuritas agregadas recientemente</h5>
        <table class="table table-dark table-borderless" style="background-color: transparent;">
            <thead style="border-bottom: 1px solid #4a5a6a;">
                <tr class="text-secondary">
                    <th>N°Figurita</th>
                    <th>Jugador</th>
                    <th>Seleccion</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.AgregadasRecientemente.Count > 0)
                {
                    @foreach (var item in Model.AgregadasRecientemente)
                    {
                        <tr style="border-bottom: 1px solid #2a3a4a;">
                            <td>
                                <span class="badge bg-secondary p-2">@item.Figurita.Numero</span>
                            </td>
                            <td>@item.Figurita.NombreJugador</td>
                            <td>@item.Figurita.Seleccion</td>
                            <td>@item.Cantidad</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4">
                            Todavía no agregaste figuritas a tu álbum.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
