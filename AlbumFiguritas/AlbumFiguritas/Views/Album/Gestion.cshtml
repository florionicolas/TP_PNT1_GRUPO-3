@model List<AlbumFiguritas.Models.Figurita>

@{
    ViewData["Title"] = "Gestionar Álbum";
}

<div class="container mt-4">

    <h2>Gestionar Álbum</h2>

    <hr />

    <form asp-action="Gestion" method="get">

    <!-- Buscador y filtros -->
    <div class="row mb-4">

        <!-- Buscar por nombre o número -->
        <div class="col-md-3">
            <input type="text"
                   name="busqueda"
                   value="@ViewBag.Busqueda"
                   class="form-control"
                   placeholder="Buscar jugador o número..." />
        </div>

        <!-- Filtro por selección -->
        <div class="col-md-3">
                <select name="seleccion" class="form-select">

                    <option value=""
                            selected="@(string.IsNullOrEmpty(ViewBag.Seleccion))">
                        Todas las selecciones
                    </option>

                    <option value="Argentina"
                            selected="@(ViewBag.Seleccion == "Argentina")">
                        Argentina
                    </option>

                    <option value="Brasil"
                            selected="@(ViewBag.Seleccion == "Brasil")">
                        Brasil
                    </option>

                    <option value="Francia"
                            selected="@(ViewBag.Seleccion == "Francia")">
                        Francia
                    </option>

                    <option value="Inglaterra"
                            selected="@(ViewBag.Seleccion == "Inglaterra")">
                        Inglaterra
                    </option>

                </select>
        </div>

        <!-- Filtrado por estado -->

            <div class="col-md-2">
                <select name="estado" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Estado))">Todos los estados</option>
                    <option value="FALTANTE" selected="@(ViewBag.Estado == "FALTANTE")">Solo Faltantes</option>
                    <option value="OBTENIDA" selected="@(ViewBag.Estado == "OBTENIDA")">Pegadas (Obtenidas)</option>
                    <option value="DUPLICADA" selected="@(ViewBag.Estado == "DUPLICADA")">Duplicadas (Para cambiar)</option>
                </select>
            </div>

        <!-- Botón buscar -->
        <div class="col-md-2">
            <button type="submit" class="btn boton-celeste w-100">
                    Buscar
            </button>
        </div>

        <!-- Botón eliminar filtro-->
        <div class="col-md-2">
            <a asp-action="Gestion"
                class="btn btn-secondary boton-filtro w-100">
                Reiniciar
            </a>
        </div>

    </div>

    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center shadow-sm" role="alert">
            No se encontraron figuritas que coincidan con la búsqueda.
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4 text-center mt-2">
            @foreach (var figurita in Model)
            {
                var diccionario = ViewBag.Cantidades as Dictionary<int, int>;
                int cantidadReal = 0;
                if (diccionario != null && diccionario.ContainsKey(figurita.Id))
                {
                    cantidadReal = diccionario[figurita.Id];
                }

                <div class="col">
                    <div class="card h-100 shadow-sm border-secondary bg-dark text-white">

                        <div class="p-2 bg-secondary rounded-top">
                            @if (!string.IsNullOrEmpty(figurita.UrlFotoJugador))
                            {
                                <img src="~/img/@(figurita.NombreJugador).png"
                                     alt="Foto de @figurita.NombreJugador"
                                     class="card-img-top img-fluid rounded shadow-sm"
                                     style="width: 150px; height: 210px; object-fit: cover;"
                                     onerror="this.onerror=null;this.src='/img/default.png';" />
                            }
                            else
                            {
                                <img src="/img/default.png" class="card-img-top img-fluid rounded" style="height: 180px; object-fit: cover;" />
                            }
                        </div>

                        <div class="card-body d-flex flex-column justify-content-between p-3">

                            <div>
                                <span class="badge bg-light text-dark mb-1">#@figurita.Numero</span>
                                <h6 class="card-title font-weight-bold text-truncate m-0" title="@figurita.NombreJugador">
                                    @figurita.NombreJugador
                                </h6>
                                <p class="card-text text-muted small mt-1 mb-2">@figurita.Seleccion</p>

                                <div class="badge @(cantidadReal > 0 ? "bg-info text-dark" : "bg-danger text-white") mb-3 fs-6 w-100 py-2 shadow-sm">
                                    Cantidad: @cantidadReal
                                </div>
                            </div>

                            <div class="d-flex justify-content-between gap-2 mt-auto">

                                <form asp-action="ActualizarCantidad" method="post" class="w-50 m-0">
                                    <input type="hidden" name="figuritaId" value="@figurita.Id" />
                                    <input type="hidden" name="cambio" value="-1" />
                                    <input type="hidden" name="busqueda" value="@ViewBag.Busqueda" />
                                    <input type="hidden" name="seleccion" value="@ViewBag.Seleccion" />
                                    <input type="hidden" name="estado" value="@ViewBag.Estado" />
                                    <button type="submit" class="btn btn-sm btn-danger w-100 fw-bold fs-5" @(cantidadReal <= 0 ? "disabled" : "")>-</button>
                                </form>

                                <form asp-action="ActualizarCantidad" method="post" class="w-50 m-0">
                                    <input type="hidden" name="figuritaId" value="@figurita.Id" />
                                    <input type="hidden" name="cambio" value="1" />
                                    <input type="hidden" name="busqueda" value="@ViewBag.Busqueda" />
                                    <input type="hidden" name="seleccion" value="@ViewBag.Seleccion" />
                                    <input type="hidden" name="estado" value="@ViewBag.Estado" />
                                    <button type="submit" class="btn btn-sm btn-success w-100 fw-bold fs-5">+</button>
                                </form>

                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>