@model List<AlbumFiguritas.Models.Figurita>

@{
    ViewData["Title"] = "Gestionar Álbum";
}

<div class="container mt-4">

    <h2>Gestionar Álbum</h2>

    <hr />

    <form asp-action="Gestion" method="get">

    <!-- Buscador y filtros -->
    <div class="row mb-4">

        <!-- Buscar por nombre o número -->
        <div class="col-md-5">
            <input type="text"
                   name="busqueda"
                   value="@ViewBag.Busqueda"
                   class="form-control"
                   placeholder="Buscar jugador o número..." />
        </div>

        <!-- Filtro por selección -->
        <div class="col-md-4">
                <select name="seleccion" class="form-select">

                    <option value=""
                            selected="@(string.IsNullOrEmpty(ViewBag.Seleccion))">
                        Todas las selecciones
                    </option>

                    <option value="Argentina"
                            selected="@(ViewBag.Seleccion == "Argentina")">
                        Argentina
                    </option>

                    <option value="Brasil"
                            selected="@(ViewBag.Seleccion == "Brasil")">
                        Brasil
                    </option>

                    <option value="Francia"
                            selected="@(ViewBag.Seleccion == "Francia")">
                        Francia
                    </option>

                    <option value="Inglaterra"
                            selected="@(ViewBag.Seleccion == "Inglaterra")">
                        Inglaterra
                    </option>

                </select>
        </div>

        <!-- Botón buscar -->
        <div class="col-md-3">
            <button type="submit" class="btn boton-celeste w-100">
                Buscar
            </button>
        </div>

    </div>

    </form>

    <!-- Resultados -->
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Número</th>
                <th>Jugador</th>
                <th>Selección</th>
                <th>Cantidad</th>
                <th>Acción</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var figurita in Model)
            {
                <tr>
                    <td>@figurita.Numero</td>
                    <td>@figurita.NombreJugador</td>
                    <td>@figurita.Seleccion</td>
                    <td>0</td>

                    <td>
                        <button class="btn btn-success">+</button>
                        <button class="btn btn-danger">-</button>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>