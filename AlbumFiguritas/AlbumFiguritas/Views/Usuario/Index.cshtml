@model IEnumerable<AlbumFiguritas.Models.Usuario>

@{
    ViewData["Title"] = "Index";
}

<h1>Listado de usuarios</h1>

<p>
    <a class="btn btn-outline-primary text-white" asp-action="Create">Crear Usuario</a>
</p>
<table class="table table-striped tabla-figuritas table-dark table-hover">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.NombreUsuario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Password)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Permiso)
            </th>
            <th>
                Acciones
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(model => item.NombreUsuario)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Email)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Password)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Permiso)
                </td>
                <td>
                    <a class="btn btn-outline-light" asp-action="Edit" asp-route-id="@item.Id">✏️</a>
                    <a class="btn btn-outline-light" asp-action="Details" asp-route-id="@item.Id">ℹ️</a>
                    <a class="btn btn-outline-light" asp-action="Delete" asp-route-id="@item.Id">❌</a>
                </td>
            </tr>
        }
    </tbody>
</table>
