@model AlbumFiguritas.Models.Usuario

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Usuario</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NombreUsuario)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NombreUsuario)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Password)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Password)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Permiso)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Permiso)
        </dd>
    </dl>

</div>
<div>
    <a class="btn btn-outline-primary text-white" asp-action="Edit" asp-route-id="@Model?.Id">Editar</a>
</div>
<a class="btn btn-outline-warning mt-3" asp-action="Index">Volver</a>
